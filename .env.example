# Database
MONGODB_URI=mongodb://localhost:27017/ascendly
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# Google Drive (video storage)
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_ROOT_FOLDER_ID=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# SMS (OTP trial verification)
SMS_PROVIDER_API_KEY=

# Email (SMTP for receipts/reminders)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@ascendly.io

# AI / LLM (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Public marketing stats (floor values; real data wins once it exceeds them)
PUBLIC_STATS_MIN_COURSES=2000
PUBLIC_STATS_MIN_MEMBERS=50000
PUBLIC_STATS_MIN_HOURS=1200000
PUBLIC_STATS_MIN_RATING=4.8

# App
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=https://ascendly.io
ENVIRONMENT=development
